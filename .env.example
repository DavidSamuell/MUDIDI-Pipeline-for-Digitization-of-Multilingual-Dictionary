# Copy to .env and fill in only the keys for backends you use.
# Never commit .env — it is gitignored.

GEMINI_API_KEY=
OPEN_ROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Optional: verbose litellm request/response logs (API errors, retries)
# LITELLM_DEBUG=1

# Optional: LLM retry / rate-limit tuning (OpenRouter + direct Gemini)
# OPENROUTER_MAX_RETRIES=8
# GEMINI_MAX_RETRIES=8
# STRUCTURED_MAX_RETRIES=3
# LLM_RATE_LIMIT_MAX_WAIT=120

# Optional: live LLM integration tests (tests/llm/test_client_reasoning_integration.py)
# MUDIDI_LLM_INTEGRATION=1
# MUDIDI_INTEGRATION_OPENAI_MODEL=openai/gpt-5-mini
# MUDIDI_INTEGRATION_ANTHROPIC_MODEL=anthropic/claude-opus-4-20250514
